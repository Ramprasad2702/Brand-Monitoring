# ══════════════════════════════════════════════════════
#  BrandMonitor — environment config
#  Copy to .env and fill in values (all are optional)
# ══════════════════════════════════════════════════════

# ── GitHub (raises rate limit from 60 → 5000 req/hr) ─
# Get free token: https://github.com/settings/tokens
GITHUB_TOKEN=

# ── HaveIBeenPwned (domain breach lookup) ────────────
# £3.50/mo: https://haveibeenpwned.com/API/Key
HIBP_API_KEY=

# ── Hunter.io (email discovery, 25 free/mo) ──────────
# https://hunter.io/api-keys
HUNTER_API_KEY=

# ── SpiderFoot (leave default if using Docker) ────────
# Start: docker run -p 5001:5001 smicallef/spiderfoot
SPIDERFOOT_URL=http://localhost:5001
SPIDERFOOT_APIKEY=

# ── RSS-Bridge (public instance or self-hosted) ───────
RSS_BRIDGE_URL=https://rss-bridge.org/bridge01/

# ── Binary paths (auto-detected from PATH if blank) ───
GITLEAKS_BIN=gitleaks
TRUFFLEHOG_BIN=trufflehog
DNSTWIST_BIN=dnstwist
AMASS_BIN=amass

# ── Results storage ───────────────────────────────────
RESULTS_DIR=/tmp/brandmonitor

# ── Optional Scrapy spider project ───────────────────
# Set to your Scrapy project dir containing a 'brand_monitor' spider
SCRAPY_SPIDER_DIR=
